<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>DJ MURATTI — TikTok Analytics</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:wght@400;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #060810;
    --surface: #0d1020;
    --surface2: #131726;
    --border: rgba(255,255,255,0.07);
    --tt: #ff2d55;
    --tt2: #00f2ea;
    --gold: #ffd166;
    --text: #e8eaf6;
    --muted: #4a5270;
    --muted2: #6b7299;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

  body {
    background: #030408;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    min-height: 100vh;
    padding: 24px 16px;
    font-family: 'DM Sans', sans-serif;
  }

  .phone {
    width: 390px;
    background: var(--bg);
    border-radius: 52px;
    border: 1.5px solid rgba(255,255,255,0.1);
    overflow: hidden;
    box-shadow:
      0 0 0 8px #08090f,
      0 0 0 10px rgba(255,255,255,0.05),
      0 50px 140px rgba(0,0,0,0.9),
      0 0 80px rgba(255,45,85,0.06);
    animation: rise 0.9s cubic-bezier(0.22,1,0.36,1) both;
  }

  @keyframes rise {
    from { opacity:0; transform: translateY(40px) scale(0.95); }
    to   { opacity:1; transform: translateY(0) scale(1); }
  }

  /* ── Dynamic Island ── */
  .island {
    position: absolute;
    top: 14px; left: 50%;
    transform: translateX(-50%);
    width: 120px; height: 34px;
    background: #000;
    border-radius: 18px;
    z-index: 100;
    display: flex; align-items: center; justify-content: center; gap: 8px;
  }

  .island-live {
    display: flex; align-items: center; gap: 4px;
    font-family: 'Space Mono', monospace;
    font-size: 9px; color: var(--tt);
    letter-spacing: 1px;
  }

  .live-dot {
    width: 6px; height: 6px;
    background: var(--tt);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--tt);
    animation: blink 1.4s ease-in-out infinite;
  }

  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

  /* ── Status Bar ── */
  .statusbar {
    height: 58px;
    display: flex; align-items: flex-end; justify-content: space-between;
    padding: 0 26px 8px;
    font-family: 'Space Mono', monospace;
    font-size: 11px; font-weight: 700;
    color: rgba(255,255,255,0.65);
    position: relative;
  }

  /* ── Scroll ── */
  .scroll {
    height: calc(844px - 58px - 80px);
    overflow-y: auto;
    scrollbar-width: none;
    padding: 0 18px 24px;
  }
  .scroll::-webkit-scrollbar { display: none; }

  /* ── Header ── */
  .header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 8px 0 20px;
  }

  .header-brand {
    display: flex; flex-direction: column;
  }

  .brand-sub {
    font-family: 'Space Mono', monospace;
    font-size: 9px; color: var(--tt);
    letter-spacing: 3px; text-transform: uppercase;
    margin-bottom: 2px;
  }

  .brand-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px; letter-spacing: 4px;
    background: linear-gradient(90deg, #fff 30%, var(--tt2) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    line-height: 1;
  }

  .tiktok-badge {
    display: flex; align-items: center; gap: 6px;
    background: rgba(255,45,85,0.12);
    border: 1px solid rgba(255,45,85,0.3);
    border-radius: 20px;
    padding: 7px 14px;
    font-size: 12px; font-weight: 700;
    color: var(--tt);
  }

  .tt-icon {
    font-size: 16px;
  }

  /* ── Hero Stat ── */
  .hero {
    background: linear-gradient(135deg, #120819 0%, #0d1525 50%, #0b1820 100%);
    border: 1px solid rgba(255,45,85,0.2);
    border-radius: 26px;
    padding: 24px 22px;
    margin-bottom: 14px;
    position: relative;
    overflow: hidden;
    animation: cardIn 0.5s 0.15s both;
  }

  @keyframes cardIn {
    from { opacity:0; transform:translateY(14px); }
    to   { opacity:1; transform:translateY(0); }
  }

  .hero::before {
    content: '';
    position: absolute; top:-60px; right:-60px;
    width: 180px; height: 180px;
    background: radial-gradient(circle, rgba(255,45,85,0.15) 0%, transparent 65%);
    border-radius: 50%;
  }

  .hero::after {
    content: '';
    position: absolute; bottom:-40px; left:-40px;
    width: 130px; height: 130px;
    background: radial-gradient(circle, rgba(0,242,234,0.08) 0%, transparent 65%);
    border-radius: 50%;
  }

  .hero-label {
    font-family: 'Space Mono', monospace;
    font-size: 10px; color: var(--muted2);
    letter-spacing: 2px; text-transform: uppercase;
    margin-bottom: 6px;
  }

  .hero-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 56px; letter-spacing: 2px;
    color: #fff;
    line-height: 1;
    text-shadow: 0 0 40px rgba(255,45,85,0.3);
    animation: countUp 1.5s 0.5s both;
  }

  @keyframes countUp {
    from { opacity:0; transform: scale(0.85); }
    to   { opacity:1; transform: scale(1); }
  }

  .hero-unit {
    font-family: 'Space Mono', monospace;
    font-size: 11px; color: var(--tt);
    letter-spacing: 1px; margin-top: 2px;
  }

  .hero-bottom {
    display: flex; gap: 16px; margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .hero-mini {
    flex: 1;
  }

  .hero-mini-val {
    font-family: 'Space Mono', monospace;
    font-size: 16px; font-weight: 700;
    color: var(--tt2);
  }

  .hero-mini-label {
    font-size: 11px; color: var(--muted2);
    margin-top: 2px;
  }

  .hero-divider {
    width: 1px;
    background: rgba(255,255,255,0.06);
  }

  /* ── Section ── */
  .section-head {
    display: flex; align-items: center; justify-content: space-between;
    margin: 20px 0 12px;
    animation: cardIn 0.5s 0.3s both;
  }

  .section-title {
    font-family: 'Space Mono', monospace;
    font-size: 11px; font-weight: 700;
    color: var(--text);
    letter-spacing: 2px; text-transform: uppercase;
    display: flex; align-items: center; gap: 8px;
  }

  .section-title::before {
    content: '';
    width: 3px; height: 14px;
    background: var(--tt);
    border-radius: 2px;
    box-shadow: 0 0 8px var(--tt);
    display: block;
  }

  .section-count {
    font-family: 'Space Mono', monospace;
    font-size: 10px; color: var(--muted2);
    background: var(--surface2);
    padding: 4px 10px; border-radius: 20px;
  }

  /* ── Proof List ── */
  .proof-list {
    display: flex; flex-direction: column; gap: 8px;
  }

  .proof-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 16px 18px;
    display: flex; align-items: center; gap: 14px;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, transform 0.15s;
    position: relative;
    overflow: hidden;
    animation: itemIn 0.4s both;
  }

  @keyframes itemIn {
    from { opacity:0; transform: translateX(-10px); }
    to   { opacity:1; transform: translateX(0); }
  }

  .proof-item:active { transform: scale(0.98); }

  .proof-item:hover {
    background: #111525;
    border-color: rgba(255,45,85,0.25);
  }

  .proof-item.rank-1 { border-color: rgba(255,209,102,0.35); }
  .proof-item.rank-2 { border-color: rgba(192,192,192,0.25); }
  .proof-item.rank-3 { border-color: rgba(205,127,50,0.25); }

  .proof-item.rank-1::before { content:''; position:absolute; top:0;left:0;right:0; height:2px; background: linear-gradient(90deg, var(--gold), transparent); }
  .proof-item.rank-2::before { content:''; position:absolute; top:0;left:0;right:0; height:2px; background: linear-gradient(90deg, #c0c0c0, transparent); }
  .proof-item.rank-3::before { content:''; position:absolute; top:0;left:0;right:0; height:2px; background: linear-gradient(90deg, #cd7f32, transparent); }

  .rank-badge {
    font-family: 'Space Mono', monospace;
    font-size: 12px; font-weight: 700;
    color: var(--muted);
    width: 28px; flex-shrink: 0;
    text-align: center;
  }

  .rank-badge.r1 { color: var(--gold); text-shadow: 0 0 10px rgba(255,209,102,0.5); }
  .rank-badge.r2 { color: #c0c0c0; }
  .rank-badge.r3 { color: #cd7f32; }

  .proof-info { flex: 1; min-width: 0; }

  .proof-user {
    font-size: 14px; font-weight: 700;
    color: var(--text);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    margin-bottom: 3px;
  }

  .proof-user span { color: var(--tt2); }

  .proof-tap {
    font-family: 'Space Mono', monospace;
    font-size: 9px; color: var(--muted);
    letter-spacing: 1.5px; text-transform: uppercase;
    display: flex; align-items: center; gap: 4px;
  }

  .proof-tap::after {
    content: '→';
    color: var(--tt);
    font-size: 11px;
  }

  .proof-views {
    font-family: 'Space Mono', monospace;
    font-size: 15px; font-weight: 700;
    color: var(--tt);
    text-align: right;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .proof-views.r1 { color: var(--gold); text-shadow: 0 0 12px rgba(255,209,102,0.4); }
  .proof-views.r2 { color: #c0c0c0; }
  .proof-views.r3 { color: #cd7f32; }

  /* ── Bottom Nav ── */
  .bottom-nav {
    position: absolute; bottom:0; left:0; right:0;
    height: 80px;
    background: rgba(8,9,16,0.97);
    backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255,255,255,0.06);
    display: flex; align-items: flex-start; justify-content: space-around;
    padding-top: 12px;
    z-index: 50;
  }

  .nav-item {
    display: flex; flex-direction: column; align-items: center; gap: 3px;
    cursor: pointer; padding: 6px 12px; border-radius: 12px;
  }

  .nav-item.active { background: rgba(255,45,85,0.1); }

  .nav-icon { font-size: 20px; }
  .nav-label {
    font-family: 'Space Mono', monospace;
    font-size: 8px; color: var(--muted); letter-spacing: 0.5px;
  }
  .nav-item.active .nav-label { color: var(--tt); }
  .nav-active-dot { width:4px;height:4px;border-radius:50%;background:var(--tt);box-shadow:0 0 6px var(--tt);margin-top:1px; }

  /* ── Load more ── */
  .load-more {
    margin-top: 16px;
    background: transparent;
    border: 1px solid rgba(255,45,85,0.3);
    border-radius: 16px;
    padding: 14px;
    text-align: center;
    cursor: pointer;
    font-family: 'Space Mono', monospace;
    font-size: 11px; color: var(--tt);
    letter-spacing: 1px;
    transition: background 0.2s;
    animation: cardIn 0.5s 0.6s both;
  }

  .load-more:active { background: rgba(255,45,85,0.08); }
</style>
</head>
<body>

<div class="phone" style="position:relative;">

  <!-- Dynamic Island -->
  <div class="island">
    <div class="island-live">
      <div class="live-dot"></div>
      LIVE DATA
    </div>
  </div>

  <!-- Status Bar -->
  <div class="statusbar">
    <span>9:41</span>
    <div style="display:flex;align-items:center;gap:5px;">
      <svg width="15" height="11" viewBox="0 0 16 12"><rect x="0" y="3" width="3" height="9" rx="1" fill="rgba(255,255,255,0.45)"/><rect x="4.5" y="2" width="3" height="10" rx="1" fill="rgba(255,255,255,0.6)"/><rect x="9" y="0" width="3" height="12" rx="1" fill="rgba(255,255,255,0.8)"/><rect x="13.5" y="0" width="2.5" height="12" rx="1" fill="white"/></svg>
      <svg width="15" height="11" viewBox="0 0 20 14"><path d="M10 2.5C12.8 2.5 15.3 3.6 17.1 5.4L18.9 3.6C16.6 1.4 13.5 0 10 0C6.5 0 3.4 1.4 1.1 3.6L2.9 5.4C4.7 3.6 7.2 2.5 10 2.5Z" fill="rgba(255,255,255,0.7)"/><path d="M10 7.5C11.6 7.5 13.1 8.1 14.2 9.2L16 7.4C14.4 5.9 12.3 5 10 5C7.7 5 5.6 5.9 4 7.4L5.8 9.2C6.9 8.1 8.4 7.5 10 7.5Z" fill="rgba(255,255,255,0.85)"/><circle cx="10" cy="12" r="2" fill="white"/></svg>
      <svg width="25" height="11" viewBox="0 0 26 12"><rect x="0" y="1" width="22" height="10" rx="3" stroke="rgba(255,255,255,0.35)" stroke-width="1" fill="none"/><rect x="1" y="2" width="16" height="8" rx="2" fill="white"/><rect x="23" y="4" width="3" height="4" rx="1.5" fill="rgba(255,255,255,0.35)"/></svg>
    </div>
  </div>

  <!-- Scroll -->
  <div class="scroll">

    <!-- Header -->
    <div class="header">
      <div class="header-brand">
        <div class="brand-sub">Analytics</div>
        <div class="brand-name">DJ MURATTI</div>
      </div>
      <div class="tiktok-badge">
        <span class="tt-icon">♪</span>
        TikTok
      </div>
    </div>

    <!-- Hero Stat -->
    <div class="hero">
      <div class="hero-label">TOP 150 TOPLAM İZLENME</div>
      <div class="hero-value" id="totalViews">—</div>
      <div class="hero-unit">TOTAL VIEWS</div>
      <div class="hero-bottom">
        <div class="hero-mini">
          <div class="hero-mini-val" id="videoCount">150</div>
          <div class="hero-mini-label">Video Kullanım</div>
        </div>
        <div class="hero-divider"></div>
        <div class="hero-mini">
          <div class="hero-mini-val" id="avgViews">—</div>
          <div class="hero-mini-label">Ortalama / Video</div>
        </div>
        <div class="hero-divider"></div>
        <div class="hero-mini">
          <div class="hero-mini-val" id="topViews">—</div>
          <div class="hero-mini-label">#1 Video Views</div>
        </div>
      </div>
    </div>

    <!-- Scan Button -->
    <button id="scanBtn" onclick="startScan()" style="
      width:100%; border:none; border-radius:18px;
      background: linear-gradient(90deg, var(--tt), #ff5277);
      color:#fff; font-family:'Space Mono',monospace;
      font-size:13px; font-weight:700; letter-spacing:2px;
      padding:16px; cursor:pointer; margin-bottom:6px;
      box-shadow: 0 8px 30px rgba(255,45,85,0.35);
      transition: transform 0.15s, box-shadow 0.15s;
      animation: cardIn 0.5s 0.2s both;
    ">
      ▶ TOP 150 ANALİZİNİ BAŞLAT
    </button>

    <div id="statusMsg" style="
      text-align:center; font-family:'Space Mono',monospace;
      font-size:10px; color:var(--muted2); letter-spacing:1px;
      min-height:20px; padding:4px 0 14px;
      animation: cardIn 0.5s 0.25s both;
    "></div>

    <!-- List Header -->
    <div class="section-head">
      <div class="section-title">Top Proof Videos</div>
      <div class="section-count" id="listCount">0 / 150</div>
    </div>

    <!-- List -->
    <div class="proof-list" id="proofList"></div>

    <div id="loadMoreWrap"></div>

  </div>

  <!-- Bottom Nav -->
  <div class="bottom-nav">
    <div class="nav-item active">
      <div class="nav-icon">🏠</div>
      <div class="nav-active-dot"></div>
    </div>
    <div class="nav-item">
      <div class="nav-icon">📊</div>
      <div class="nav-label">STATS</div>
    </div>
    <div class="nav-item">
      <div class="nav-icon">🎵</div>
      <div class="nav-label">MUSIC</div>
    </div>
    <div class="nav-item">
      <div class="nav-icon">⚙️</div>
      <div class="nav-label">SETTINGS</div>
    </div>
  </div>

</div>

<script>
const API_KEY = "49084773d8msh07a4a9c1ac5d484p108e2ejsn2cf663d07caa";
const HOST = "tiktok-scraper7.p.rapidapi.com";
const MUSIC_ID = "7087325412228859906";

let allVideos = [];
let displayedCount = 0;
const PAGE_SIZE = 20;

function fmt(n) {
  if (n >= 1000000) return (n/1000000).toFixed(1) + 'M';
  if (n >= 1000) return (n/1000).toFixed(1) + 'K';
  return n.toLocaleString();
}

function fmtFull(n) {
  return n.toLocaleString('en-US');
}

function getRankClass(i) {
  if(i===0) return 'rank-1';
  if(i===1) return 'rank-2';
  if(i===2) return 'rank-3';
  return '';
}

function getRankBadge(i) {
  if(i===0) return '<span class="rank-badge r1">#1</span>';
  if(i===1) return '<span class="rank-badge r2">#2</span>';
  if(i===2) return '<span class="rank-badge r3">#3</span>';
  return `<span class="rank-badge">#${i+1}</span>`;
}

function getViewClass(i) {
  if(i===0) return 'r1';
  if(i===1) return 'r2';
  if(i===2) return 'r3';
  return '';
}

function renderItems(from, to) {
  const list = document.getElementById('proofList');
  for(let i = from; i < to && i < allVideos.length; i++) {
    const v = allVideos[i];
    const uid = v.author?.unique_id || 'user';
    const vid = v.video_id || v.id || '';
    const url = `https://www.tiktok.com/@${uid}/video/${vid}`;
    const plays = v.play_count || 0;
    const delay = ((i - from) * 0.04).toFixed(2);

    const el = document.createElement('div');
    el.className = `proof-item ${getRankClass(i)}`;
    el.style.animationDelay = `${delay}s`;
    el.onclick = () => window.open(url, '_blank');
    el.innerHTML = `
      ${getRankBadge(i)}
      <div class="proof-info">
        <div class="proof-user"><span>@${uid}</span></div>
        <div class="proof-tap">Tap to view proof</div>
      </div>
      <div class="proof-views ${getViewClass(i)}">${fmtFull(plays)}</div>
    `;
    list.appendChild(el);
  }
  displayedCount = Math.min(to, allVideos.length);
  document.getElementById('listCount').textContent = `${displayedCount} / ${allVideos.length}`;

  // Load more button
  const wrap = document.getElementById('loadMoreWrap');
  if(displayedCount < allVideos.length) {
    wrap.innerHTML = `<div class="load-more" onclick="loadMore()">+ ${Math.min(PAGE_SIZE, allVideos.length - displayedCount)} DAHA FAZLA YÜKLEYİN</div>`;
  } else {
    wrap.innerHTML = '';
  }
}

function loadMore() {
  renderItems(displayedCount, displayedCount + PAGE_SIZE);
}

function setStatus(msg) {
  document.getElementById('statusMsg').textContent = msg;
}

async function startScan() {
  const btn = document.getElementById('scanBtn');
  btn.disabled = true;
  btn.textContent = '⟳ Taranıyor...';
  document.getElementById('proofList').innerHTML = '';
  document.getElementById('loadMoreWrap').innerHTML = '';
  displayedCount = 0;
  allVideos = [];
  document.getElementById('totalViews').textContent = '—';
  document.getElementById('avgViews').textContent = '—';
  document.getElementById('topViews').textContent = '—';
  document.getElementById('listCount').textContent = '0 / 150';

  const headers = {
    "x-rapidapi-key": API_KEY,
    "x-rapidapi-host": HOST
  };

  try {
    let cursor = "0";
    for(let page = 0; page < 5; page++) {
      setStatus(`Sayfa ${page+1}/5 yükleniyor... (${allVideos.length} video)`);
      const res = await fetch(`https://${HOST}/music/posts?music_id=${MUSIC_ID}&count=30&cursor=${cursor}`, { headers });
      const json = await res.json();
      const data = json.data || {};
      const vids = data.videos || [];
      if(!vids.length) break;
      allVideos.push(...vids);
      cursor = data.cursor || '0';
      if(!data.hasMore) break;
      await new Promise(r => setTimeout(r, 200));
    }

    allVideos = allVideos.slice(0, 150);
    allVideos.sort((a,b) => (b.play_count||0) - (a.play_count||0));

    const total = allVideos.reduce((s,v) => s + (v.play_count||0), 0);
    const avg = allVideos.length ? Math.round(total / allVideos.length) : 0;
    const top = allVideos[0]?.play_count || 0;

    document.getElementById('totalViews').textContent = fmtFull(total);
    document.getElementById('avgViews').textContent = fmt(avg);
    document.getElementById('topViews').textContent = fmt(top);

    setStatus(`✓ ${allVideos.length} video analiz edildi`);
    renderItems(0, PAGE_SIZE);

    btn.textContent = '↺ YENİLE';
    btn.disabled = false;

  } catch(e) {
    setStatus('⚠ Veri çekme hatası. Lütfen tekrar deneyin.');
    btn.textContent = '▶ TOP 150 ANALİZİNİ BAŞLAT';
    btn.disabled = false;
  }
}
</script>
</body>
</html>
